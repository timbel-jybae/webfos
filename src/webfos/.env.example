# Webfos Backend Environment Variables

# === 기본 설정 ===
PROJECT_NAME=Webfos
VERSION=0.1.0
DEBUG=true

# === 서버 설정 ===
HOST=0.0.0.0
PORT=32055
RELOAD=true
WORKERS=1

# === LiveKit 설정 ===
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_TIMEOUT=10.0

# === HLS 소스 설정 ===
HLS_SOURCE_URL=https://cdnlive.wowtv.co.kr/wowtvlive/livestream/playlist.m3u8
DEFAULT_ROOM_NAME=webfos-room

# === 로깅 ===
LOG_LEVEL=INFO
